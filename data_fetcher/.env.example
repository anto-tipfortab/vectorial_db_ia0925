# ── RabbitMQ connection ────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_QUEUE=papers

# ── arXiv search ───────────────────────────────────────────────────────────────
ARXIV_CATEGORIES=cs.AI,cs.LG,cs.CL
PAPERS_PER_RUN=50
INTERVAL_MINUTES=5

# ── Shared volume paths ────────────────────────────────────────────────────────
PDF_OUTPUT_DIR=/shared/pdfs
SEEN_IDS_FILE=/shared/seen_ids.json