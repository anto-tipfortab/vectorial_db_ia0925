# ── RabbitMQ connection ────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_QUEUE=papers

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=arxiv_papers

# ── Gemini ─────────────────────────────────────────────────────────────────────
# GOOGLE_API_KEY injected by docker-compose from root .env
EMBEDDING_MODEL=models/gemini-embedding-001

# ── Rate limiting ──────────────────────────────────────────────────────────────
# Free tier: 100 req/min → use 2.0s delay, concurrency 1
# Paid tier: 1000 req/min → use 0.0s delay, concurrency 2+
EMBED_BATCH_DELAY=3.0
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ── Shared volume paths ────────────────────────────────────────────────────────
PROCESSED_DIR=/shared/processed